// MCQ MasterLoop — multi-curriculum MCQ practice platform
//
// Schema design notes:
// - Questions and options are polymorphic ContentBlock JSON so a single
//   question can mix text, LaTeX (math), images, and graphs without a
//   table-per-type explosion. The renderer dispatches on `kind`.
// - Attempt rows are the audit/analytics backbone: every answer ever
//   given lives here, never updated. Wrong-only retry queues and
//   mastery progress are computed from this table.
// - The seven gamification tables (Streak, StreakFreeze, League, etc.)
//   are intentionally separate from the practice tables so progression
//   logic can evolve without migrations on the hot path.
// - Contributor monetization (Phase 3) is sketched but not implemented;
//   the columns exist so we don't need a breaking migration later.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Curriculum taxonomy ─────────────────────────────────────────────────────
// Curriculum → Subject → Chapter → (optional) Unit → Question
// PaperStyle and Year are FREE-TEXT tags on Question so we don't need to
// model every CIE / IB / AP paper variant up front.

model Curriculum {
  id          String         @id @default(cuid())
  code        String         @unique
  displayName String
  description String?
  sortOrder   Int            @default(0)
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  subjects    Subject[]
  examCalendar ExamCalendarEntry[]
  reviewerAssignments ReviewerAssignment[]
  bounties    Bounty[]

  @@map("curriculums")
}

model ExamCalendarEntry {
  id           String     @id @default(cuid())
  curriculumId String
  title        String
  examDate     DateTime
  region       String     @default("Global")
  notes        String?
  createdAt    DateTime   @default(now())
  curriculum   Curriculum @relation(fields: [curriculumId], references: [id], onDelete: Cascade)

  @@index([curriculumId, examDate])
  @@map("exam_calendar_entries")
}

model Subject {
  id           String     @id @default(cuid())
  curriculumId String
  code         String // e.g. "PHY", "MATH", "BIO"
  name         String
  description  String?
  iconKey      String? // lucide icon name for the picker grid
  accentColor  String? // hex for the subject's card on the home grid
  sortOrder    Int        @default(0)
  isActive     Boolean    @default(true)
  // AP subjects may include Free Response Questions alongside MCQ.
  // When true, the subject detail page shows an FRQ disclaimer.
  hasFrq       Boolean    @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  curriculum   Curriculum @relation(fields: [curriculumId], references: [id], onDelete: Cascade)
  chapters         Chapter[]
  questions        Question[]
  subjectProgress  SubjectProgress[]
  reviewerAssignments ReviewerAssignment[]
  bounties         Bounty[]
  topics           Topic[]

  @@unique([curriculumId, code])
  @@map("subjects")
}

// ─── Curriculum Topic tree ───────────────────────────────────────────────────
// A coded, hierarchical syllabus taxonomy imported from the School-Core
// curriculum library (LibraryStrand) — one subtree per subject, any framework
// (IGCSE / A-Level / AP / IB / CBSE). Additive: sits alongside Chapter/Unit; a
// Question may carry an optional topicId for syllabus-precise tagging.
model Topic {
  id         String   @id @default(cuid())
  subjectId  String
  parentId   String?
  code       String   // framework code, e.g. "IGCSE.PHY.1.4"
  title      String
  level      Int      @default(1) // 1=Area, 2=Strand, 3=Sub-strand, 4=Standard
  examWeight Float?   // % of the exam, from the library's metadata
  sortOrder  Int      @default(0)
  source     String?  // provenance, e.g. "school-core:CAMBRIDGE_IGCSE"
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  subject   Subject    @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  parent    Topic?     @relation("TopicTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  Topic[]    @relation("TopicTree")
  questions Question[]

  @@unique([subjectId, code])
  @@index([subjectId, parentId])
  @@map("topics")
}

model Chapter {
  id          String     @id @default(cuid())
  subjectId   String
  name        String
  description String?
  sortOrder   Int        @default(0)
  isActive    Boolean    @default(true)
  // IB DP SL/HL classification. Null for non-IB chapters.
  // "SL" = Standard Level only, "HL" = Higher Level only, "BOTH" = common to SL and HL
  ibLevel     String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  subject     Subject    @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  units       Unit[]
  questions   Question[]
  bounties    Bounty[]

  @@unique([subjectId, name])
  @@map("chapters")
}

model Unit {
  id        String     @id @default(cuid())
  chapterId String
  name      String
  description String?
  sortOrder Int        @default(0)
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  chapter   Chapter    @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  questions Question[]

  @@unique([chapterId, name])
  @@map("units")
}

// ─── Questions + Options ─────────────────────────────────────────────────────
// Single-correct MCQ first; multi-correct + drag-drop deferred to phase 2.
// `stem` and each `option.content` are JSON ContentBlock — see types.ts.

enum QuestionDifficulty {
  EASY
  MEDIUM
  HARD
  CHALLENGE
}

enum QuestionStatus {
  DRAFT
  IN_SUBJECT_REVIEW
  IN_CURRICULUM_REVIEW
  // Curriculum-approved but NOT yet visible to students — awaiting admin QA test.
  IN_QA
  PUBLISHED
  ARCHIVED
}

enum ReviewerScope {
  SUBJECT
  CURRICULUM
}

enum BountyStatus {
  OPEN       // no active claim
  CLAIMED    // a contributor has claimed it (claimExpiresAt is in the future)
  FULFILLED  // filledCount == count; all required questions submitted + approved
  CLOSED     // manually closed by the reviewer who created it (or admin)
}

model Question {
  id            String             @id @default(cuid())
  subjectId     String
  chapterId     String
  unitId        String?
  // Optional syllabus-precise tag from the imported curriculum Topic tree.
  topicId       String?
  // Free-text tags that capture the "paper-style" filter: year of the
  // syllabus, term/session, paper number, topic codes. Kept as a JSON
  // array of strings so adding/removing tags doesn't need a migration.
  // Example: ["2024", "Paper 2", "May/June", "kinematics"]
  tags          Json               @default("[]")
  // ContentBlock[] — see src/lib/questions/types.ts for the shape
  stem          Json
  // Inline explanation shown after the user answers (right or wrong).
  // Also a ContentBlock[] so we can embed diagrams in the explanation.
  explanation   Json?
  // When true, the UI shows checkboxes and requires the user to select ALL
  // correct options before submitting. Drives AP-style "select two" questions.
  allowMultipleCorrect Boolean @default(false)
  difficulty    QuestionDifficulty @default(MEDIUM)
  status        QuestionStatus     @default(DRAFT)
  // Build year — the exam year this question targets (e.g. 2024).
  year          Int?
  // Marketing flag: "this question was AI-drafted and reviewed by a human"
  // surfaces in the question detail and in T&C compliance reports.
  aiAssisted    Boolean            @default(false)
  // Free-text citation: "Original — Dr Smith" or "Inspired by CIE 0625/12 Q14".
  // NEVER store verbatim past-paper text; only meta references.
  sourceNote    String?
  // The Contributor who authored it (for revenue share).
  authorId      String?
  // Optional link back to the bounty this question fulfilled. Set automatically
  // when the contributor has an active claim matching the question's scope.
  bountyId      String?
  // The Admin/SuperAdmin who approved publication.
  publishedById String?
  publishedAt   DateTime?
  // The admin who passed QA (IN_QA → PUBLISHED). Scalar — full trail is in QuestionReview.
  qaPassedById  String?
  qaPassedAt    DateTime?
  // Denormalised pointers updated on each review decision so the reviewer queue
  // doesn't need to join QuestionReview. Full audit trail lives in QuestionReview.
  lastReviewerId String?
  lastReviewNote String?
  // Originality cross-check vs the Original Question Bank (top match only).
  simScore       Float?    // 0..1 cosine similarity to the closest original
  simCitation    String?   // e.g. "0625/12 M/J 2021 Q14"
  simOriginalId  String?
  simCheckedAt   DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  subject       Subject            @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  chapter       Chapter            @relation(fields: [chapterId], references: [id], onDelete: Restrict)
  unit          Unit?              @relation(fields: [unitId], references: [id], onDelete: SetNull)
  topic         Topic?             @relation(fields: [topicId], references: [id], onDelete: SetNull)
  author        User?              @relation("QuestionAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  publishedBy   User?              @relation("QuestionPublisher", fields: [publishedById], references: [id], onDelete: SetNull)
  lastReviewer  User?              @relation("QuestionLastReviewer", fields: [lastReviewerId], references: [id], onDelete: SetNull)
  bounty        Bounty?            @relation(fields: [bountyId], references: [id], onDelete: SetNull)
  options       QuestionOption[]
  attempts      Attempt[]
  reviews       QuestionReview[]
  reports       QuestionReport[]
  wrongAnswers  WrongAnswer[]

  @@index([subjectId, chapterId, status])
  @@index([authorId])
  @@map("questions")
}

model QuestionOption {
  id         String   @id @default(cuid())
  questionId String
  // ContentBlock — text | image | math | graph | mixed
  content    Json
  // The correct option for single-correct MCQs. Future multi-correct
  // questions can set this true on multiple rows.
  isCorrect  Boolean  @default(false)
  // Per-option explanation shown when this option is selected and wrong.
  rationale  String?
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@map("question_options")
}

// ─── Practice + attempts ─────────────────────────────────────────────────────

enum AttemptMode {
  PRACTICE
  WRONG_RETRY
  EXAM
  BOSS
}

model Attempt {
  id              String      @id @default(cuid())
  userId          String
  questionId      String
  // Which option the user picked. Null if they ran out of time / skipped.
  selectedOptionId String?
  isCorrect       Boolean     @default(false)
  // Seconds spent on this question.
  timeSeconds     Int         @default(0)
  // The user's self-rated confidence (the metacognition layer described
  // in the strategic plan). Optional — only stored when the UI prompts.
  confidence      String? // "high" | "medium" | "low"
  mode            AttemptMode @default(PRACTICE)
  // The PracticeSession this attempt belongs to (so we can score sessions
  // independently of individual attempts).
  sessionId       String?
  // XP awarded for this attempt (varies by mode, difficulty, confidence).
  xpAwarded       Int         @default(0)
  createdAt       DateTime    @default(now())
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  question        Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)
  session         PracticeSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([userId, questionId, createdAt])
  @@index([userId, mode, createdAt])
  @@index([sessionId])
  @@map("attempts")
}

enum SessionStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

// A PracticeSession is one filtered "round" of questions — either
// section practice, a wrong-only retry queue, or a timed exam.
model PracticeSession {
  id              String        @id @default(cuid())
  userId          String
  mode            AttemptMode
  // Snapshot of the filter the user picked (curriculum/subject/chapter/year).
  // Lets us show "you practised Cambridge IGCSE Physics — Forces, 2024-style"
  // on review screens.
  filter          Json
  // Question IDs the session will iterate through, in order.
  questionIds     Json
  // Shuffled option order per question: { [questionId]: optionId[] }
  // Null for PRACTICE sessions (options shown in canonical DB order).
  // Set at session-creation time for WRONG_RETRY so the order is stable
  // across refreshes but different from the student's previous attempt.
  optionOrders    Json?
  // Index into questionIds the user is currently on.
  currentIndex    Int           @default(0)
  status          SessionStatus @default(IN_PROGRESS)
  // For EXAM mode: server-anchored deadline. Null for PRACTICE / WRONG_RETRY.
  expiresAt       DateTime?
  startedAt       DateTime      @default(now())
  completedAt     DateTime?
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  attempts        Attempt[]

  @@index([userId, status])
  @@map("practice_sessions")
}

// ─── Mastery tracking ────────────────────────────────────────────────────────
// Aggregated views of Attempt data. Updated via cron job + on-demand
// recompute. NOT the source of truth — Attempts are. Keep this as a
// projection so reads stay fast.

model SubjectProgress {
  id              String   @id @default(cuid())
  userId          String
  subjectId       String
  // Running counts.
  attempted       Int      @default(0)
  correct         Int      @default(0)
  masteryPercent  Float    @default(0) // 0–100
  // Per-chapter breakdown.
  chapterStats    Json     @default("[]") // [{ chapterId, attempted, correct, mastery }]
  lastPracticedAt DateTime?
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject         Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([userId, subjectId])
  @@index([userId])
  @@map("subject_progress")
}

// ─── Wrong-answer queue ──────────────────────────────────────────────────────
// One row per (user, question) the user has gotten wrong AND not yet
// re-attempted successfully. Drives the "Wrong-Answer Graveyard" page
// and the wrong-only retry sessions.

model WrongAnswer {
  id            String    @id @default(cuid())
  userId        String
  questionId    String
  // The first wrong attempt that landed this row here.
  firstWrongAt  DateTime  @default(now())
  // How many times the user has retried this question.
  retryCount    Int       @default(0)
  // Cleared when the user gets it right on retry; the row is then archived,
  // not deleted, so the Graveyard can show "vanquished" tombstones.
  resolvedAt    DateTime?
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  question      Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
  @@index([userId, resolvedAt])
  @@map("wrong_answers")
}

// ─── Users + auth ────────────────────────────────────────────────────────────
// NextAuth v5 adapter tables. Keep the auth model lean — student-specific
// preferences (avatar, daily XP goal, etc.) live on a sibling table so the
// hot User row stays small.

enum UserRole {
  SUPER_ADMIN
  // Co-founder: full content + team oversight (Question Bank, admins),
  // finance is view-only (no money movement). Sits above ADMIN.
  CO_FOUNDER
  ADMIN
  CONTRIBUTOR
  STUDENT
}

enum UserStatus {
  ACTIVE
  PENDING
  SUSPENDED
  DELETED
}

model User {
  id                String     @id @default(cuid())
  email             String     @unique
  emailVerified     DateTime?
  // bcrypt hash. Null when the user only signs in via OAuth.
  password          String?
  firstName         String
  lastName          String
  image             String?
  role              UserRole   @default(STUDENT)
  status            UserStatus @default(ACTIVE)
  // Parental-consent flag for under-13 accounts (COPPA / GDPR-K).
  // Required before AI features or social leaderboards activate.
  parentalConsentAt DateTime?
  dateOfBirth       DateTime?
  // MFA
  mfaEnabled        Boolean    @default(false)
  mfaSecret         String? // encrypted, optional
  mfaBackupCodes    String? // JSON array of bcrypt-hashed codes
  // Password-reset state
  passwordResetToken     String?   @unique
  passwordResetExpiresAt DateTime?
  // Stripe Connect (contributor payouts)
  stripeConnectId   String?
  // Audit
  lastLoginAt       DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  // NextAuth adapter tables
  accounts          Account[]
  sessions          Session[]
  userSessions      UserSession[]
  // Domain relations
  attempts          Attempt[]
  practiceSessions  PracticeSession[]
  subjectProgress   SubjectProgress[]
  wrongAnswers      WrongAnswer[]
  questionsAuthored     Question[]           @relation("QuestionAuthor")
  questionsPublished    Question[]           @relation("QuestionPublisher")
  questionsLastReviewed Question[]           @relation("QuestionLastReviewer")
  reviewerAssignments   ReviewerAssignment[]
  bountiesCreated       Bounty[]             @relation("BountyCreator")
  bountiesClaimed       Bounty[]             @relation("BountyClaimer")
  questionReviews   QuestionReview[]
  questionReports   QuestionReport[]
  preferences       UserPreferences?
  streak            Streak?
  xpTotal           XpLedger[]
  badges            BadgeAward[]
  leagues           LeagueMembership[]
  squadMemberships  SquadMember[]
  marathonEntries   MarathonEntry[]
  subscription      Subscription?
  auditLogs         AuditLog[]
  contributorApplication ContributorApplication?
  contributorPayouts     ContributorPayout[]

  @@map("users")
}

// Per-user settings + cosmetic state. Pulled out so the User row doesn't
// bloat with every new preference.
model UserPreferences {
  id              String   @id @default(cuid())
  userId          String   @unique
  // Daily XP goal — Easy 10 / Normal 20 / Hard 30 / Insane 50.
  dailyXpGoal     Int      @default(20)
  // Picked curriculum + subjects. Filters the home grid.
  primaryCurriculumId String?
  enabledSubjectIds   String[] @default([])
  // Avatar cosmetics keyed by category.
  avatar          Json     @default("{}")
  // Soundboard preferences.
  soundsEnabled   Boolean  @default(true)
  hapticsEnabled  Boolean  @default(true)
  reducedMotion   Boolean  @default(false)
  // Leaderboard visibility: full | first-name | initials | hidden.
  leaderboardVisibility String @default("first-name")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

// ─── NextAuth adapter tables ─────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("auth_sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// Step-up MFA + session revocation tracking. Schema mirrors School-Core's
// proven pattern.
model UserSession {
  id            String    @id @default(cuid())
  userId        String
  ipAddress     String?
  userAgent     String?   @db.Text
  provider      String?
  createdAt     DateTime  @default(now())
  lastSeenAt    DateTime  @default(now())
  revokedAt     DateTime?
  revokedBy     String?
  mfaVerifiedAt DateTime?
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@map("user_sessions")
}

// ─── Gamification ────────────────────────────────────────────────────────────
// Streak / Streak Freeze / League / Badge / XP — the engagement spine.
// All append-only or per-user-singleton; no joins on the hot path.

model Streak {
  id              String   @id @default(cuid())
  userId          String   @unique
  current         Int      @default(0)
  longest         Int      @default(0)
  lastActiveDate  DateTime?
  freezesAvailable Int     @default(1) // refilled weekly
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("streaks")
}

model StreakFreeze {
  id        String   @id @default(cuid())
  userId    String
  usedFor   DateTime // the calendar date the freeze covered
  consumedAt DateTime @default(now())

  @@index([userId, usedFor])
  @@map("streak_freezes")
}

// XP is append-only — every awarded delta is a row. Lets us show
// "today's XP", "this week", and full lifetime without aggregation drift.
model XpLedger {
  id        String   @id @default(cuid())
  userId    String
  delta     Int
  reason    String // "correct_easy" | "boss_win" | "streak_bonus" | ...
  attemptId String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("xp_ledger")
}

enum LeagueTier {
  BRONZE
  SILVER
  GOLD
  DIAMOND
  CHAMPION
}

model League {
  id        String     @id @default(cuid())
  tier      LeagueTier
  // Each league lasts one calendar week. Identifier is "{tier}-{yyyy-ww}".
  weekTag   String
  startsAt  DateTime
  endsAt    DateTime
  createdAt DateTime   @default(now())
  members   LeagueMembership[]

  @@unique([tier, weekTag])
  @@index([endsAt])
  @@map("leagues")
}

model LeagueMembership {
  id         String   @id @default(cuid())
  leagueId   String
  userId     String
  weeklyXp   Int      @default(0)
  rank       Int? // computed at week end
  promoted   Boolean? // null = ongoing; true/false = settled
  joinedAt   DateTime @default(now())
  league     League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([leagueId, userId])
  @@index([userId])
  @@map("league_memberships")
}

model Badge {
  id          String       @id @default(cuid())
  key         String       @unique // "first_perfect" | "ten_streak" | "subject_master_phy"
  name        String
  description String
  iconKey     String
  rarity      String       @default("common") // common | rare | epic | legendary
  awards      BadgeAward[]

  @@map("badges")
}

model BadgeAward {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  awardedAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@map("badge_awards")
}

model Squad {
  id          String        @id @default(cuid())
  name        String
  inviteCode  String        @unique
  createdById String
  createdAt   DateTime      @default(now())
  members     SquadMember[]

  @@map("squads")
}

model SquadMember {
  id       String @id @default(cuid())
  squadId  String
  userId   String
  isLeader Boolean @default(false)
  joinedAt DateTime @default(now())
  squad    Squad  @relation(fields: [squadId], references: [id], onDelete: Cascade)
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([squadId, userId])
  @@map("squad_members")
}

// ─── Marathon events ──────────────────────────────────────────────────────────

model MarathonEvent {
  id          String           @id @default(cuid())
  title       String
  questionIds String[]
  startsAt    DateTime
  endsAt      DateTime
  createdAt   DateTime         @default(now())
  entries     MarathonEntry[]

  @@map("marathon_events")
}

model MarathonEntry {
  id         String        @id @default(cuid())
  eventId    String
  userId     String
  score      Int           @default(0)
  xpEarned   Int           @default(0)
  finishedAt DateTime?
  event      MarathonEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@map("marathon_entries")
}

// ─── Subscriptions / billing ─────────────────────────────────────────────────
// One row per user; nullable while we're free-tier-only.

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  EXPIRED
}

enum SubscriptionPlan {
  FREE
  PRO
  PRO_FAMILY
}

enum SubscriptionSource {
  STRIPE // web
  APP_STORE // iOS IAP
  PLAY_STORE // Android IAP
  COMP // comp / promo
}

model Subscription {
  id                 String              @id @default(cuid())
  userId             String              @unique
  plan               SubscriptionPlan    @default(FREE)
  status             SubscriptionStatus  @default(ACTIVE)
  source             SubscriptionSource? // null while plan=FREE
  // Stripe ids (web) — null for IAP-sourced subscriptions.
  stripeCustomerId       String?
  stripeSubscriptionId   String?
  stripePriceId          String?
  // IAP receipts (mobile) — stored encrypted in production.
  iapOriginalTxId        String?
  // Common period state.
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelAtPeriodEnd  Boolean             @default(false)
  trialEndsAt        DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

// ─── Contributor marketplace ──────────────────────────────────────────────────

model ContributorApplication {
  id        String   @id @default(cuid())
  userId    String   @unique
  status    String   @default("PENDING")
  statement String   @db.Text
  sampleUrl String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("contributor_applications")
}

model ContributorPayout {
  id               String   @id @default(cuid())
  userId           String
  amountCents      Int
  periodStart      DateTime
  periodEnd        DateTime
  status           String   @default("PENDING")
  stripeTransferId String?
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("contributor_payouts")
}

// ─── Contributor moderation (Phase 3 stubs) ──────────────────────────────────

model QuestionReview {
  id         String   @id @default(cuid())
  questionId String
  reviewerId String
  // approve | reject | needs_changes | reassign | admin_override
  decision   String
  // The stage the decision was made at: subject | curriculum | admin
  stage      String   @default("curriculum")
  notes      String?
  createdAt  DateTime @default(now())
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  reviewer   User     @relation(fields: [reviewerId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@map("question_reviews")
}

// A (User, Scope) tuple granting review rights at the subject or curriculum
// tier. A single user can hold many — e.g. SubjectReviewer for Physics under
// IGCSE plus CurriculumReviewer for the entire AS Level catalog.
model ReviewerAssignment {
  id           String        @id @default(cuid())
  userId       String
  scope        ReviewerScope
  subjectId    String?       // set when scope = SUBJECT
  curriculumId String?       // set when scope = CURRICULUM
  createdAt    DateTime      @default(now())
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject      Subject?      @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  curriculum   Curriculum?   @relation(fields: [curriculumId], references: [id], onDelete: Cascade)

  @@unique([userId, scope, subjectId, curriculumId])
  @@index([subjectId])
  @@index([curriculumId])
  @@map("reviewer_assignments")
}

// A request from a Curriculum Reviewer for N questions matching a specific
// scope (subject + optional chapter / year / difficulty). Contributors browse
// open bounties, claim one (soft 7-day lock), submit questions tagged with the
// bountyId; when the count is met the bounty is FULFILLED.
model Bounty {
  id             String              @id @default(cuid())
  curriculumId   String
  subjectId      String
  chapterId      String?             // null = any chapter in the subject
  year           Int?                // null = any year
  difficulty     QuestionDifficulty? // null = any difficulty
  count          Int                 @default(1)
  filledCount    Int                 @default(0)
  notes          String?
  status         BountyStatus        @default(OPEN)
  createdById    String
  claimedById    String?
  claimedAt      DateTime?
  claimExpiresAt DateTime?           // 7 days from claimedAt — checked on read
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  curriculum     Curriculum          @relation(fields: [curriculumId], references: [id], onDelete: Cascade)
  subject        Subject             @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  chapter        Chapter?            @relation(fields: [chapterId], references: [id], onDelete: SetNull)
  createdBy      User                @relation("BountyCreator", fields: [createdById], references: [id], onDelete: Cascade)
  claimedBy      User?               @relation("BountyClaimer", fields: [claimedById], references: [id], onDelete: SetNull)
  questions      Question[]

  @@index([status, curriculumId])
  @@index([claimedById])
  @@map("bounties")
}

model QuestionReport {
  id         String   @id @default(cuid())
  questionId String
  reporterId String
  // bug | bad_answer | bad_explanation | copyright | other
  category   String
  notes      String?
  resolved   Boolean  @default(false)
  createdAt  DateTime @default(now())
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  reporter   User     @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([questionId, resolved])
  @@map("question_reports")
}

// ─── Original Question Bank ──────────────────────────────────────────────────
// Real past-paper MCQs (e.g. CAIE), stored ONLY for internal similarity
// comparison against contributor questions. Expressive content (stem/options)
// is AES-GCM ENCRYPTED at rest and decrypted only via an audited, case-by-case
// reveal — never bulk-readable, even by a Super Admin. Access gated to
// SUPER_ADMIN (canViewOriginals). Slice 2 adds the embedding (pgvector) +
// lexical signatures used for the actual matching.
model OriginalQuestion {
  id             String   @id @default(cuid())
  board          String   @default("CAIE")
  syllabusCode   String   // e.g. "0625"
  subjectName    String   // e.g. "Physics"
  level          String   // "IGCSE" | "AS_A_LEVEL"
  session        String   // "FM" (Feb/March) | "MJ" (May/June) | "ON" (Oct/Nov)
  year           Int
  paper          Int      // 1, 2
  variant        Int      // 1, 2, 3
  questionNumber Int
  tier           String?  // "CORE" | "EXTENDED" | null
  // Encrypted expressive content. NULL in fingerprint-only mode (Option A) —
  // the text is discarded after embedding and never stored.
  stemCipher     String?  @db.Text
  optionsCipher  String?  @db.Text
  // Clear, non-expressive metadata.
  answer         String   // "A".."D"
  citation       String   // e.g. "0625/12 M/J 2021 Q14"
  // Non-reversible fingerprints (the comparison artifacts):
  //  - embedding: 384-dim semantic vector (pgvector, all-MiniLM-L6-v2; needs the
  //    `vector` extension). Written via raw SQL.
  //  - normHash: sha256 of normalized text, for exact/verbatim-copy detection.
  embedding      Unsupported("vector(384)")?
  normHash       String?
  createdById    String?
  createdAt      DateTime @default(now())

  @@unique([syllabusCode, session, year, paper, variant, questionNumber])
  @@index([syllabusCode, level, subjectName])
  @@index([subjectName, normHash])
  @@map("original_questions")
}

// ─── Audit ───────────────────────────────────────────────────────────────────
// Lighter than School-Core's audit log — we don't have multi-tenant
// blast radius — but keeps the pattern for question moderation +
// admin actions.

model AuditLog {
  id        String   @id @default(cuid())
  userId    String? // null = system event
  action    String // "QUESTION_PUBLISHED" | "USER_SUSPENDED" | ...
  entity    String
  entityId  String?
  metadata  Json     @default("{}")
  ipAddress String?
  userAgent String?  @db.Text
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([entity, entityId])
  @@map("audit_log")
}
