# MCQuest — environment variables.
# Copy to .env.local for dev. Never commit real values.

# ─── Core ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ─── Auth ──────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Bootstrap allowlist — comma-separated emails / domains that may sign up
# via OAuth while public registration is closed.
SIGN_IN_ALLOWED_EMAILS=""
SIGN_IN_ALLOWED_DOMAINS=""

# Google OAuth (Google Cloud Console → Credentials → Web client)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# AES-256 key (hex, 64 chars). Used to encrypt sensitive fields at rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=""

# ─── Database ──────────────────────────────────────────────────────────────
# Supabase pooler connection (use Transaction mode for serverless).
DATABASE_URL=""

# ─── Email (Resend) ────────────────────────────────────────────────────────
RESEND_API_KEY=""

# ─── Object storage (Cloudflare R2) ────────────────────────────────────────
# Used for question images, graphs, and avatar uploads.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_PUBLIC_BASE_URL=""

# ─── Payments (Stripe) ─────────────────────────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# ─── Rate limiting (Upstash Redis) ─────────────────────────────────────────
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ─── Error monitoring (Sentry) ─────────────────────────────────────────────
SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
NEXT_PUBLIC_SENTRY_DSN=""

# ─── AI providers (for question-drafting tools) ────────────────────────────
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
